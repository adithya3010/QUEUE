# MongoDB Connection
# Get your MongoDB connection string from MongoDB Atlas
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Server Port
PORT=5000

# JWT Secret Key
# Generate a strong secret using: openssl rand -base64 32
# Or use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your_strong_jwt_secret_here

# JWT Refresh Secret (Optional - uses JWT_SECRET if not provided)
# Generate a different secret for refresh tokens
JWT_REFRESH_SECRET=your_strong_refresh_secret_here

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Sentry Error Tracking (Optional)
# Get your DSN from https://sentry.io after creating a project
# Leave empty to disable Sentry
SENTRY_DSN=

# Logging Configuration (Optional)
# Set to 'true' to enable file logging in development
ENABLE_FILE_LOGGING=false

# Set to 'true' to enable logging during tests
ENABLE_TEST_LOGGING=false
